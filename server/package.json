{
  "name": "sketchquest-server",
  "version": "1.0.0",
  "description": "Backend for SketchQuest - real-time drawing game",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run",
    "migrate:rollback": "knex migrate:rollback"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "knex": "^2.5.1",
    "mysql2": "^3.6.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/node": "^20.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "keywords": [
    "game",
    "drawing",
    "multiplayer",
    "realtime"
  ],
  "author": "Your Name",
  "license": "MIT"
}
